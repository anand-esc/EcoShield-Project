graph TD
    classDef user fill:#3b82f6,stroke:#1d4ed8,stroke-width:2px,color:#fff,font-weight:bold
    classDef ui fill:#10b981,stroke:#047857,stroke-width:2px,color:#fff,font-weight:bold
    classDef process fill:#f59e0b,stroke:#b45309,stroke-width:2px,color:#fff,font-weight:bold
    classDef end_state fill:#8b5cf6,stroke:#6d28d9,stroke-width:2px,color:#fff,font-weight:bold

    U((User)):::user
    UI[Next.js Dashboard]:::ui
    API[FastAPI Backend]:::process
    Cache{Local Cache Hit?}:::process
    Result[Display Compliance Blueprint]:::end_state
    Export[Copy / Download PDF]:::user

    U -->|1. Enters Chemicals & Location| UI
    UI -->|2. Clicks 'Generate Blueprint'| Cache
    
    Cache -->|Yes| Result
    Cache -->|No| API

    API -->|3. Extracts Hazards| API
    API -->|4. Formulates Vector Query| API
    API -->|5. Retrieves Laws from Supabase| API
    API -->|6. Synthesizes JSON Checklist| API
    
    API -->|7. Returns Payload| UI
    UI -->|8. Saves to Cache| UI
    UI --> Result
    
    Result -->|9. Clicks Export Buttons| Export
    Export -->|Format as Printable Document| U
